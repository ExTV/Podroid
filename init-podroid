#!/bin/sh
# Podroid initramfs bootstrap — mounts overlay, switch_root to /sbin/init.
# All system bringup logic now lives in /etc/init.d/podroid-* services
# on the Alpine squashfs.
set -e

mount -t proc    proc      /proc  -o noexec,nosuid,nodev
mount -t sysfs   sys       /sys   -o noexec,nosuid,nodev
mount -t devtmpfs devtmpfs /dev   -o exec,nosuid,mode=0755,size=2M

echo "Mounting storage..." > /dev/console

# virtio_blk is built-in; modprobe is a no-op safety net
[ -d "/lib/modules/$(uname -r)" ] && { depmod -a 2>/dev/null; modprobe virtio_blk 2>/dev/null; }

# /dev/vda = persistent ext4 (user data, container storage)
# /dev/vdb = read-only Alpine squashfs (system files)
mkdir -p /mnt/persist /mnt/lower /mnt/overlay

# Persistent: format on first boot if needed.
# noatime: stop atime writes on every read.
# commit=60: journal commits every 60s (default 5s) — 12× less journal IO
#   under bursty container ops. Risk on power loss is bounded to the last
#   60s of writes, which the user can mitigate with `sync` if it matters.
# nobarrier: write barriers are unnecessary inside the VM because QEMU's
#   cache=writeback layer already gives us host-level barriers on flush.
#   Saves journal-commit syscalls on every metadata change.
if ! mount -t ext4 -o rw,noatime,commit=60,barrier=0 /dev/vda /mnt/persist 2>/dev/null; then
    e2fsck -y /dev/vda >/dev/null 2>&1 || mkfs.ext4 -q -F /dev/vda
    mount -t ext4 -o rw,noatime,commit=60,barrier=0 /dev/vda /mnt/persist
fi

echo "Mounting system..." > /dev/console
mount -t squashfs -o ro /dev/vdb /mnt/lower \
    || { echo "FATAL: squashfs (/dev/vdb) mount failed" > /dev/console; exec sh; }

mkdir -p /mnt/persist/upper /mnt/persist/work
echo "Stacking overlay..." > /dev/console
mount -t overlay overlay \
    -o lowerdir=/mnt/lower,upperdir=/mnt/persist/upper,workdir=/mnt/persist/work,metacopy=on,redirect_dir=on,index=on \
    /mnt/overlay \
    || { echo "FATAL: overlay mount failed" > /dev/console; exec sh; }

# Move /mnt/persist into the new root so users can reach raw storage,
# and so switch_root can fully clear initramfs (no orphan mounts left
# under /mnt that would block its unlink pass).
mkdir -p /mnt/overlay/mnt/persist
mount --move /mnt/persist /mnt/overlay/mnt/persist

# Move /mnt/lower (the squashfs) too — keeps /dev/vdb mount visible in the
# new root, and lets initramfs cleanup unlink /mnt cleanly.
mkdir -p /mnt/overlay/mnt/lower
mount --move /mnt/lower /mnt/overlay/mnt/lower

# Move our early mounts into the new root so OpenRC inherits them
mount --move /proc /mnt/overlay/proc
mount --move /sys  /mnt/overlay/sys
mount --move /dev  /mnt/overlay/dev

exec /sbin/switch_root /mnt/overlay /sbin/init
